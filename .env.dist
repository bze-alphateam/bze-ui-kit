# Chain configuration
NEXT_PUBLIC_CHAIN_ID=beezee-1
NEXT_PUBLIC_CHAIN_NAME=beezee
NEXT_PUBLIC_CHAIN_IS_TESTNET=false
NEXT_PUBLIC_CHAIN_ADDRESS_PREFIX=bze
NEXT_PUBLIC_CHAIN_NATIVE_ASSET_DENOM=ubze
NEXT_PUBLIC_USDC_IBC_DENOM=
NEXT_PUBLIC_EXPLORER_URL=https://explorer.chaintools.tech
NEXT_PUBLIC_WALLET_CHAINS_NAMES=
NEXT_PUBLIC_LOCKER_ADDRESS=bze1pc5zjcvhx3e8l305zjl72grytfa30r5mdypmw4
NEXT_PUBLIC_GAS_MULTIPLIER=1.5
# Fallback only — the real gas price is fetched from the chain's txfeecollector
# validator_min_gas_fee param at runtime. Used when that query fails.
NEXT_PUBLIC_GAS_PRICE=0.02
NEXT_PUBLIC_NON_NATIVE_GAS_MULTIPLIER=1.5
# Slippage buffer applied when paying tx fees in a non-native (foreign) denom.
# Multiplies the AMM-converted fee amount to absorb pool drift between simulation
# and inclusion. Default 1.1 (10%). Must be >= 1.
NEXT_PUBLIC_FOREIGN_FEE_SLIPPAGE=1.1
NEXT_PUBLIC_APP_NAME=BZE

# BZE endpoints
NEXT_PUBLIC_REST_URL=https://rest.getbze.com
NEXT_PUBLIC_RPC_URL=https://rpc.getbze.com
NEXT_PUBLIC_REST_ENDPOINT=https://rest.getbze.com
NEXT_PUBLIC_RPC_ENDPOINT=https://rpc.getbze.com
NEXT_PUBLIC_AGG_API_HOST=https://getbze.com

# IBC chain RPC endpoints
NEXT_PUBLIC_RPC_URL_ARCHWAY=https://rpc.mainnet.archway.io
NEXT_PUBLIC_RPC_URL_OSMOSIS=https://rpc.osmosis.zone
NEXT_PUBLIC_RPC_URL_NOBLE=https://rpc.mainnet.noble.strange.love
NEXT_PUBLIC_RPC_URL_JACKAL=https://rpc.jackalprotocol.com
NEXT_PUBLIC_RPC_URL_FLIX=https://rpc.omniflix.network
NEXT_PUBLIC_RPC_URL_ATOMONE=https://rpc.atom.one

# IBC chain REST endpoints
NEXT_PUBLIC_REST_URL_ARCHWAY=https://api.mainnet.archway.io
NEXT_PUBLIC_REST_URL_OSMOSIS=https://lcd.osmosis.zone
NEXT_PUBLIC_REST_URL_NOBLE=https://rest.mainnet.noble.strange.love
NEXT_PUBLIC_REST_URL_JACKAL=https://api.jackalprotocol.com
NEXT_PUBLIC_REST_URL_FLIX=https://rest.omniflix.network
NEXT_PUBLIC_REST_URL_ATOMONE=https://rest.atom.one

# Ecosystem navigation overrides (optional)
# Exclude apps from the "Other" dropdown (comma-separated keys: website, staking, dex, burner, factory)
NEXT_PUBLIC_ECOSYSTEM_EXCLUDED=
# Override link URLs (useful for testnet deployments)
NEXT_PUBLIC_ECOSYSTEM_LINK_WEBSITE=https://getbze.com
NEXT_PUBLIC_ECOSYSTEM_LINK_STAKING=https://staking.getbze.com
NEXT_PUBLIC_ECOSYSTEM_LINK_DEX=https://dex.getbze.com
NEXT_PUBLIC_ECOSYSTEM_LINK_BURNER=https://burner.getbze.com
NEXT_PUBLIC_ECOSYSTEM_LINK_FACTORY=
# Override labels (optional)
NEXT_PUBLIC_ECOSYSTEM_LABEL_WEBSITE=
NEXT_PUBLIC_ECOSYSTEM_LABEL_STAKING=
NEXT_PUBLIC_ECOSYSTEM_LABEL_DEX=
NEXT_PUBLIC_ECOSYSTEM_LABEL_BURNER=
NEXT_PUBLIC_ECOSYSTEM_LABEL_FACTORY=

# AtomOne validator (optional, used by dex)
NEXT_PUBLIC_ATONE_VALIDATOR_SUPPORTED_DENOMS=
NEXT_PUBLIC_ATONE_VALIDATOR_PAGE_URL=
